header#header(class="w-full fixed bottom-0 z-20")
    nav#navbar(class="w-full h-16 bg-transparent flex items-center justify-center ease-in-out duration-[2000ms] z-3")
        .mobileBar#mobileBar(class=" flex lg:hidden w-10/12 justify-center md:justify-start ")
            div(class="overlay w-0 fixed h-full z-4 left-0 top-0 overflow-hidden bg-[rgba(0,0,0,0.9)] ease-in-out duration-300" id="myNav")
                <a href="javascript:void(0)" class="closebtn  text-5xl absolute bottom-4 text-center w-full text-white" onclick="closeNav()">&times;</a>
                div(class="overlay-content relative top-1/4 w-full mt-1/3 text-5xl text-rose-200 px-4 ")
                    +navLink("../","Home","Ir al Inicio","block py-2")
                    +navLinkDisabled("../portfolio","Portfolio","Portfolio","block py-2")
                    +navLinkDisabled("../projects","Projects","Projects","block py-2") 
                    +navLink("../blog","Blog","Blog","block py-2")
            .span.fa-solid.fa-bars(class="text-3xl" id="openbtn" onClick="openNav()")
        .menuBar#menuBar(class="z-3 hidden w-10/12 max-w-screen-lg")
            .menuItems(class="flex justify-end w-full")
                .ul(class="flex justify-end space-x-6")
                    .li 
                        +navLink("../","Home","Home")
                    .li 
                        +navLinkDisabled("../portfolio","Portfolio","Portfolio")
                    .li
                        +navLinkDisabled("../projects","Projects","Projects")
                    .li 
                        +navLinkDisabled("../blog","Blog","Blog")
                    .Li 
                        +ctabtn("Resume","https://drive.google.com/file/d/12VcNT3hCMh66BBBfCs5uea6m_VDQnAD4/view?usp=sharing","px-6","resumebtn")

    