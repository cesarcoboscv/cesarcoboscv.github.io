nav#navbar(class="w-full h-16 bg-[rgba(252,252,252,0.3)] text-black flex items-center justify-center ease-in-out duration-1000 text-lg font-light")
    .mobileBar#mobileBar(class=" flex lg:hidden w-10/12 justify-center md:justify-start")
        div(class="overlay w-0 fixed h-screen z-2 left-0 top-0 overflow-hidden bg-[rgba(0,0,0,0.9)]" id="myNav")
            <a href="javascript:void(0)" class="closebtn text-white text-5xl absolute bottom-16 text-center w-full" onclick="closeNav()">&times;</a>
            div(class="overlay-content relative top-1/4 w-full mt-1/3 text-5xl text-white")
                +navLink("../","Home","Ir al Inicio","block py-2")
                +navLink("../portfolio","Portafolio","Portafolio","block py-2")
                +navLink("../projects","Proyectos","Proyectos","block py-2") 
                +navLink("../blog","Blog","Blog","block py-2")
        .span.fa-solid.fa-bars(class="text-3xl" id="openbtn" onClick="openNav()")
    .menuBar#menuBar(class="hidden w-10/12 max-w-screen-lg")
        .menuItems(class="flex justify-end w-full")
            .ul(class="flex justify-center w-5/12 space-x-6")
                .li 
                    +navLink("../","Home","Ir al Inicio")
                .li 
                    +navLink("../portfolio","Portafolio","Portafolio")
                .li
                    +navLink("../projects","Proyectos","Proyectos")
                .li 
                    +navLink("../blog","Blog","Blog")

    