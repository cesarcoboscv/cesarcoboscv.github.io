nav#navbar(class="w-full h-16 bg-[#141E30] flex items-center justify-center ease-in-out duration-1000 text-lg z-3")
    .mobileBar#mobileBar(class=" flex lg:hidden w-10/12 justify-center md:justify-start")
        div(class="overlay w-0 fixed h-full z-4 left-0 top-0 overflow-hidden bg-[rgba(0,0,0,0.9)]" id="myNav")
            <a href="javascript:void(0)" class="closebtn  text-5xl absolute bottom-4 text-center w-full" onclick="closeNav()">&times;</a>
            div(class="overlay-content relative top-1/4 w-full mt-1/3 text-5xl text-white px-4")
                +navLink("../","Home","Ir al Inicio","block py-2")
                +navLink("../portfolio","Portfolio","Portfolio","block py-2")
                +navLink("../projects","Projects","Projects","block py-2") 
                +navLink("../blog","Blog","Blog","block py-2")
        .span.fa-solid.fa-bars(class="text-3xl" id="openbtn" onClick="openNav()")
    .menuBar#menuBar(class="z-3 hidden w-10/12 max-w-screen-lg")
        .menuItems(class="flex justify-end w-full")
            .ul(class="flex justify-end space-x-6")
                .li 
                    +navLink("../","Home","Home")
                .li 
                    +navLink("../portfolio","Portfolio","Portfolio")
                .li
                    +navLink("../projects","Projects","Projects")
                .li 
                    +navLink("../blog","Blog","Blog")
                .Li 
                    +ctabtn("Resume","../cv","px-6","resumebtn")

    