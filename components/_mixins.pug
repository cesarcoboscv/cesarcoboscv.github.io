mixin socialLink(link,icon,title)
    a(href=link rel="noreferrer" target="_blank" class="hover:scale-150 hover:text-rose-600 ease-in-out duration-300" title=title)
        span.fa-brands(class=icon)
        
mixin navLink(link,name,title,class1)
    a(href=link rel="noreferrer" target="_self" class="hover:text-rose-600 hover:underline decoration-rose-600 decoration-2 underline-offset-4" title=title class=class1)=name

mixin toolIcon(link,alt,name)
    div.toolIcon(class="w-16 h-16 hover:scale-150 ease-in-out duration-200 flex flex-col justify-center items-center")
        img(width=40 height=40 src=link alt=alt)
        p.toolName(class="text-xs mt-1")=name

mixin blogCard(title,date,description,image,altimage)
    div.card(class="w-72 h-auto rounded-3xl p-3 hover:bg-slate-800 ease-in-out duration-200  hover:scale-110 hover:shadow-xl")
        .image
            img(class="rounded-2xl" src=image, alt=altimage, srcset="")
        .content
            p(class="font-bold mt-4")=title
            p(class="text-sm text-red-400 mb-4")=date
            p(class="mb-4")=description
        .div(class="flex justify-end")
            button(type="button" class="text-white bg-transparent  hover:bg-rose-600 focus:ring-4 focus:ring-red-200  rounded-lg text-sm px-8 py-1 mr-2 mb-2 focus:outline-none") Read

mixin heroSection(image,title)
    section(class="h-48 md:h-72 w-full flex items-center justify-start mt-[-64px] md:mt-0 " style=image class="bg-center bg-no-repeat bg-cover shadow-2xl")
        div(class="w-auto  h-auto mx-16 ")
            p(class="w-auto text-4xl md:text-5xl font-bold text-rose-600 mt-4 mb-2")=title

mixin jsScripts()
    script(src="../assets/js/scroll.js")
    script(src="../assets/js/device.js")
    script(src="../assets/js/nav.js")

mixin head(pagetitle)
    meta(charset="UTF-8")
    meta(http-equiv="X-UA-Compatible", content="IE=edge")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    //- Styles
    link(rel="stylesheet", href="../assets/css/style.css")
    //- Icons
    script(src="https://kit.fontawesome.com/32dce108fb.js" crossorigin="anonymous")
    //- Fonts
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Karla:wght@200;300;400;600;700;800&display=swap" rel="stylesheet")
    
    title=pagetitle

mixin ctabtn(text,link,class1,ids)
    a(href=link class="active:border-rose-600 ease-in-out duration-500  text-rose-600  hover:text-white  border-solid border-2 border-rose-600 ease-in-out duration-200 hover:bg-rose-600 focus:ring-4 focus:ring-rose-200  rounded-lg py-2 px-4 " class=class1 id=ids)=text

mixin htmls()
    html(lang="en" class="bg-[#141E30] scroll-smooth font-karla font-light text-[rgba(255,255,255,0.5)]")

mixin tabWork(event,ids,name)
     button(class="tablinks cursor-pointer block w-32 h-12 border-solid  hover:border-rose-600 border-[rgba(255,255,255,0.5)] border-2 rounded-3xl bg-transparent ease-in-put duration-300 py-2 px-4 text-center md:text-center" onclick=event id=ids)=name