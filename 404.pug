include ./components/_mixins
doctype html
include ./components/_head.pug
    head
        +head("Portfolio")
    body
        header#header(class="w-full fixed bottom-0 z-20")
            include ./components/_header.pug

        main(class="md:pt-16 w-full h-full flex justify-center")
            div(class="w-10/12 lg:w-full h-1/2 flex flex-col  text-center")
                p(class="text-6xl md:text-8xl my-16 text-rose-600 font-bold scale-x-[-1] scale-y-[-1] ") Oh! no! 
                p(class="text-4xl md:text-5xl my-8 text-rose-400") The page doesn't exist 
                P(class="text-3xl md:text-4xl mb-16 text-rose-200") Don't worry, you can get back by clicking on menu up there
                P(class="text-3xl md:text-4xl mb-16 text-rose-200") or
                P(class="text-3xl md:text-4xl mb-16 text-rose-200") you can send me a message by clicking down here
                
        footer
            include ./components/_footer.pug

        +jsScripts()