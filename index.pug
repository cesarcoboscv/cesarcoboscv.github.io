include ./components/_mixins
doctype html
include ./components/_head.pug
    +pageTitle("Home")
        //-Script
    style. 
        .toolIcon {
            color:transparent;
        }
        .toolIcon:hover {
            color: #1e293b;
            font-weight:600;
        }
        .carousel:hover .controls {
            opacity: 1;
        }
        .controls{
            justify-content: space-between;
        }
        .slides {
            transform: translateY(-50%);
            transition: 1s ease-in-out all;
        }
        .slide {
            min-width: 100%;     
            height: auto;
        }
        .tab button.active {
            border: 4px solid #e11d48;
            color: #e11d48;
            width: 160px;
            font-weight: 600;
        }
        .back{
            z-index: -3;
            transform:scale(-1);
        }
        //- .outliner{
        //-     text-shadow:
        //-     -1px -1px 0 #fda4af,
        //-     1px -1px 0 #fda4af,
        //-     -1px 1px 0 #fda4af,
        //-     1px 1px 0 #fda4af; 
        //- }

    body
        .back#back(class="bg-no-repeat bg-cover h-full w-[1200px] md:w-[2400px] fixed" style="background-image: url('https://drive.google.com/uc?export=view&id=18W8szmspLib9voDR41IyFPNp9R7RluWT')")
        //- .back#back(class="bg-no-repeat bg-cover h-full w-[2400px] fixed" style="background-image: url('https://images.unsplash.com/photo-1560276036-9546721ff5d4?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=766&q=80')")
        include ./components/_header.pug

        main
            include ./components/_heroSection.pug
            include ./components/_aboutSection.pug
            //- include ./components/_projectSection.pug
            include ./components/_myToolssection.pug
            include ./components/_workedSection.pug
            include ./components/_blogEntriesSection.pug

        include ./components/_footer.pug

        +jsScripts()
        script(src="./assets/js/tabs.js") 