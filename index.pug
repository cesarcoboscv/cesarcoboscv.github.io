include ./components/_mixins
doctype html
include ./components/_head.pug
    +pageTitle("Home")
        //-Script
    style. 
        .toolIcon {
            color:transparent;
        }
        .toolIcon:hover {
            color: #1e293b;
            font-weight:600;
        }
        .carousel:hover .controls {
            opacity: 1;
        }
        .controls{
            justify-content: space-between;
        }
        .slides {
            transform: translateY(-50%);
            transition: 1s ease-in-out all;
        }
        .slide {
            min-width: 100%;     
            height: auto;
        }
        .tab button.active {
            border: 4px solid #e11d48;
            color: #e11d48;
            width: 160px;
            font-weight: 600;
        }
        //- .outliner{
        //-     text-shadow:
        //-     -1px -1px 0 #fda4af,
        //-     1px -1px 0 #fda4af,
        //-     -1px 1px 0 #fda4af,
        //-     1px 1px 0 #fda4af; 
        //- }

    body
        include ./components/_header.pug

        main
            include ./components/_heroSection.pug
            include ./components/_aboutSection.pug
            //- include ./components/_projectSection.pug
            include ./components/_myToolssection.pug
            include ./components/_workedSection.pug
            include ./components/_blogEntriesSection.pug

        include ./components/_footer.pug

        +jsScripts()
        script(src="./assets/js/tabs.js") 